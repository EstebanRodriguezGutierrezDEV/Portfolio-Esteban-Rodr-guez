---
import pythonPdf from "../assets/pdf/CursoPython.pdf";
import scrapingPdf from "../assets/pdf/Scraping.pdf";
import bigschoolPdf from "../assets/pdf/Bigschool.pdf";
import CursoAnimacionesCSS from "../assets/pdf/CursoAnimacionesCSS.pdf";
import CursoAstro from "../assets/pdf/Curso-Astro.pdf";
import CursoCSSGrid from "../assets/pdf/Curso-CSS-Grid.pdf";
import CursoCSS from "../assets/pdf/Curso-CSS.pdf";
import CursoGSAP from "../assets/pdf/Curso-GSAP.pdf";
import CursoHTML from "../assets/pdf/Curso-HTML.pdf";
import TituloBigData from "../assets/pdf/Titulo BigData.pdf";
import TituloCiber from "../assets/pdf/Titulo CiberSeguridad.pdf";
