>
    <div class="flex items-center justify-between px-2">
        <h2
            class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent"
            data-i18n="certifications.title"
        >
            Certificaciones
        </h2>
    </div>


        <div
            id="cert-carousel"
            class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide scroll-smooth"
        >
            <!-- Página 1: Python, Scraping, BIG School, DAM -->
            <div
                class="flex-none w-full snap-start grid grid-cols-1 sm:grid-cols-2 gap-4 pr-1"
            >
