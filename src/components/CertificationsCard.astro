                    href={pythonPdf}
                    target="_blank"
                    class="flex items-center gap-4 p-4 rounded-3xl bg-white/50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 transition-all duration-300 hover:bg-white dark:hover:bg-slate-800 hover:scale-[1.02] hover:shadow-lg group/item overflow-hidden"
